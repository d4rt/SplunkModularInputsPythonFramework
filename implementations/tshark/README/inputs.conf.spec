[tshark://<name>]

* tshark command, environment variables in the format $VARIABLE$ can be included and they will be substituted ie: $SPLUNK_HOME$
tshark_command= <value>

* tshark filter
tshark_filter= <value>

* tshark output format (PDML or PSML)
tshark_output = <value>

* pcap path, location of pcap files
pcap_path = <value>

* remove pcap when complete set to true or false
pcap_remove = <value>

